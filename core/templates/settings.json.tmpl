{
  "_comment_top": "Humanless Pipeline settings.json — generated by install.sh. Hooks use {{HOME}} and {{NODE_MODULES}} placeholders resolved at install time.",
  "permissions": {
    "_comment": "allow: tools Claude can use freely. deny: destructive commands that require explicit user confirmation.",
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Skill",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)"
    ]
  },
  "hooks": {
    "_comment_hooks": "Core pipeline hooks. Pack-specific hooks are appended by pack installers.",
    "PreToolUse": [
      {
        "_comment": "Bash command validation — blocks dangerous commands, enforces TDD gate on commits, runs pre-commit lint and validation.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/dev-server-block.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/validate-bash.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/tdd-gate.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/pre-commit-lint.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/pre-commit-validate.sh"
          },
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/pretooluse.mjs 2>/dev/null || true"
          }
        ]
      },
      {
        "_comment": "WebFetch interception — routes through context-mode for indexing.",
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/pretooluse.mjs 2>/dev/null || true"
          }
        ]
      },
      {
        "_comment": "Read interception — context-mode optimization for file reads.",
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/pretooluse.mjs 2>/dev/null || true"
          }
        ]
      },
      {
        "_comment": "Grep interception — context-mode optimization for searches.",
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/pretooluse.mjs 2>/dev/null || true"
          }
        ]
      },
      {
        "_comment": "Edit/Write guards — protects config files, detects secrets, enforces TDD on edits, ensures logging in new functions.",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/config-protection.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/secret-detection.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/tdd-gate-edit.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/logging-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_comment": "Post-Bash — triggers code review after commits, tracks task completion.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/post-commit-review.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/task-completion.sh"
          }
        ]
      },
      {
        "_comment": "Post-Edit/Write — auto-format, check for debug statements left behind.",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/post-edit-format.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/debug-statement-check.sh"
          }
        ]
      },
      {
        "_comment": "Context-mode post-tool tracking for all tools.",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/posttooluse.mjs 2>/dev/null || true"
          }
        ]
      },
      {
        "_comment": "Universal post-tool — cost tracking for all tool invocations.",
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/cost-tracker.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "_comment": "Capture learnings from every subagent completion.",
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/learnings-capture.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "_comment": "Session initialization — context-mode, pipeline health, DLQ check, MCP health.",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/sessionstart.mjs 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/pipeline-health.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/dlq-check.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/mcp-health-check.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "_comment": "Save handoff state before context compaction so work is not lost.",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/pre-compact-handoff.sh"
          },
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/precompact.mjs 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_comment": "Session end — persist session state for recovery.",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/session-persist.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_comment": "Prompt processing — task dispatch, team routing, requirement interpretation.",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/task-dispatcher.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/prompt-team-router.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/requirement-interpreter.sh"
          },
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT={{NODE_MODULES}}/context-mode node {{NODE_MODULES}}/context-mode/hooks/userpromptsubmit.mjs 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux"
}
